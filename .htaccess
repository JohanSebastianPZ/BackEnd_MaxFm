Options -Indexes

# ── Pasar el header Authorization a PHP ──────────────────────────────────────
# Apache por defecto lo descarta. Estas dos líneas lo restauran.
RewriteEngine On
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1

# ── Seguridad: bloquear acceso directo a archivos sensibles ──────────────────
<FilesMatch "\.(env|db|sql|log)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ── CORS preflight para Apache (complementa el cors.php) ─────────────────────
<IfModule mod_headers.c>
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization"
</IfModule>
