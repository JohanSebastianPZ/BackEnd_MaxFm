# URL del frontend React (sin barra al final)
# En local suele ser el puerto de Vite (8080, 8081, etc.)
FRONTEND_URL_LOCAL=http://localhost:8081

# URL del frontend en producción / red local
FRONTEND_URL_PROD=http://0.0.0.0:8080

# Nombre del archivo de base de datos SQLite
DB_NAME=database.db

# Zona horaria del servidor
# Ejemplos: Europe/Madrid, America/Bogota, America/Mexico_City
TIMEZONE=Europe/Madrid
